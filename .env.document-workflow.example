# Kopieer naar .env en pas aan. Zelfde CAMUNDA_WORKER_TOKEN in API, worker-container en deep-agents.

CAMUNDA_WORKER_TOKEN=vervang-door-lang-random-string
IOU_API_URL=http://host.docker.internal:8000
IOU_API_TOOL_BASE_URL=http://host.docker.internal:8000

# Voor iou-api (host of container):
IOU_DOCUMENT_WORKFLOW=camunda
ZEEBE_ADDRESS=127.0.0.1:26500
CAMUNDA_BPMN_PROCESS_ID=DocumentPipeline
DEEP_AGENT_SERVICE_URL=http://127.0.0.1:8091

# Optioneel: geen Deep Agent-stap in BPMN (variabele runDeepAgent wordt door gateway gezet)
# CAMUNDA_RUN_DEEP_AGENT=false

# Optioneel: S3-compatibele opslag (bijv. MinIO in Docker) voor pipeline-artefacten via iou-api
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_BUCKET=iou-documents
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_PATH_STYLE=true
# S3_REGION=us-east-1
