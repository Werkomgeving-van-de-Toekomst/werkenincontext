# IOU-Modern Environment Configuration

# Server settings
HOST=0.0.0.0
PORT=8000

# Database (DuckDB - embedded, no server needed)
DATABASE_PATH=data/iou-modern.duckdb

# Authentication
JWT_SECRET=change-this-in-production

# NL Wallet (MinBZK verification_server) — nodig voor POST /api/id/nl-wallet/sessions
# Start stack: ./scripts/nl-wallet-verification-up.sh (na setup-devenv in nl-wallet clone)
# Poort meestal 3011 — zie nl-wallet scripts/configuration.sh (VERIFICATION_SERVER_PORT)
# NL_WALLET_VERIFICATION_SERVER_URL=http://127.0.0.1:3011
# E2E: docs/nl-wallet-e2e.md — demo UI: http://127.0.0.1:8000/nl-wallet-e2e.html

# Verifiable Presentation login (POST /api/auth/wallet)
# VC_TRUSTED_ISSUERS=did:key:...,did:web:...
# VC_STRICT_MODE=false

# Logging
RUST_LOG=info

# Optional: AI model settings (for future use)
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small

# Primaire cloud-LLM (Mistral/OpenAI-compatibel) — gebruikt door iou-ai in-process en door iou-ai-service /v1/chat
# LLM_API_KEY=
# LLM_MODEL=mistral-small-latest
# LLM_BASE_URL=https://api.mistral.ai

# Lokale SLM (Ollama, vLLM, …) — iou-ai-service /v1/slm/chat en create_slm_provider_from_env()
# Standaard model (licht, document + agents): qwen2.5:3b — zie docs/architecture/ollama-models.md
# Mistral via Ollama: SLM_MODEL=ministral-3:3b (licht) of SLM_MODEL=mistral (7B)
# SLM_BASE_URL=http://127.0.0.1:11434
# SLM_MODEL=qwen2.5:3b
# SLM_API_KEY=

# Aparte AI-gateway (cargo run -p iou-ai-service of Docker)
# IOU_AI_SERVICE_HOST=0.0.0.0
# IOU_AI_SERVICE_PORT=8090
# IOU_AI_SERVICE_TOKEN=
# Clients/workers: IOU_AI_SERVICE_URL=http://127.0.0.1:8090

# Python deep-agents worker (Camunda) — zie services/deep-agents-worker
# DEEP_AGENT_SERVICE_URL=http://127.0.0.1:8091
