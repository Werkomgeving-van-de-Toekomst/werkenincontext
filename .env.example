# IOU-Modern Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://iou_user:iou_password@localhost:5432/iou_modern
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=iou_modern
DATABASE_USER=iou_user
DATABASE_PASSWORD=iou_password

# =============================================================================
# Storage (MinIO/S3)
# =============================================================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=iou-documents

# =============================================================================
# Application
# =============================================================================
RUST_LOG=debug
RUST_BACKTRACE=1
HOST=0.0.0.0
PORT=8080

# =============================================================================
# Security
# =============================================================================
JWT_SECRET=change-me-in-production
SESSION_TIMEOUT_MINUTES=60

# =============================================================================
# AI Services
# =============================================================================
OLLAMA_URL=http://localhost:11434
NEDERLANDSE_AI_API_KEY=
NEDERLANDSE_AI_URL=

# =============================================================================
# Feature Flags
# =============================================================================
SQLX_OFFLINE=false
ENABLE_SWAGGER=true
